# Copia este archivo a .env y reemplaza los valores.
# Para Gmail usa clave de aplicacion, no tu contrasena normal.

# App
SECRET_KEY=cambia-esta-clave-en-produccion
DEBUG=false
ALLOWED_HOSTS=127.0.0.1,localhost,tu-app.onrender.com
CSRF_TRUSTED_ORIGINS=https://tu-app.onrender.com

# Base de datos (Render/Railway suelen proveer DATABASE_URL)
DATABASE_URL=sqlite:///db.sqlite3
DB_SSL_REQUIRE=true

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_clave_de_aplicacion
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=tu_correo@gmail.com
